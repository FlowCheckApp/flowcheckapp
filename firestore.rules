/**
 * FlowCheck — Firestore Security Rules
 * ─────────────────────────────────────────────────────────────
 * Deploy via: firebase deploy --only firestore:rules
 *
 * Architecture:
 *  - /users/{uid}/** — users can ONLY read/write their own data
 *  - /plaid_items/**  — NO client access at all (Admin SDK only)
 *
 * These rules run AFTER Firebase Auth verifies the request.
 * The backend (Admin SDK) bypasses all rules — it has full access
 * regardless. Rules only restrict client SDK calls.
 * ─────────────────────────────────────────────────────────────
 */

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Caller is the owner of this user document
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Fields allowed when CREATING a user doc (complete doc — all fields listed).
    // Entitlement fields ('pro','is_pro','pro_expires_at') are intentionally NOT
    // listed here — only the backend (RevenueCat webhook + referral grant) may
    // write them. Letting clients seed `is_pro:true` at signup bypasses payment.
    function allowedUserCreateFields() {
      return request.resource.data.keys().hasOnly([
        'uid', 'name', 'email', 'phone',
        'created_at', 'last_seen', 'last_streak_date',
        'plaid_linked', 'plaid_institution', 'plaid_institution_id', 'plaid_linked_at',
        'streak',
        'goals', 'budgets',
        'notifications_enabled', 'biometric_enabled',
        'email_marketing_opt_in',
        'onboarding_goal', 'onboarding_income', 'onboarding_complete', 'onboarding_attribution',
        'tour_completed',
        // FCM token — may be written via set+merge on fresh installs before doc exists
        'fcm_token', 'fcm_updated_at',
        // Terms acceptance
        'terms_accepted_at', 'terms_version',
        // Referral — stored at signup if the user entered a referral code
        'referred_by',
        // Referral code — deterministic, generated client-side
        'referral_code',
      ]);
    }

    // Fields the CLIENT is allowed to CHANGE on update.
    // Intentionally separate from create — backend writes many fields
    // (last_synced, credit_score, fcm_token, plaid_linked, etc.) that must
    // not block client writes just because they exist in the document.
    // Using affectedKeys() means we only restrict what's being changed,
    // not what the document already contains.
    function allowedUserUpdateFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name', 'email', 'phone',
        'last_seen', 'last_streak_date',
        'streak',
        'goals', 'budgets',
        'notifications_enabled', 'biometric_enabled',
        'email_marketing_opt_in',
        'onboarding_goal', 'onboarding_income', 'onboarding_complete',
        'onboarding_attribution',
        'tour_completed',
        'fcm_token', 'fcm_updated_at',
        'terms_accepted_at', 'terms_version',
        // Referral system — client generates and persists its own code
        'referral_code',
      ]);
    }

    // ─── /plaid_items — server-only, no client access ──────────
    // The backend (Admin SDK) stores Plaid access_tokens here.
    // Clients must never see or write to this collection.
    match /plaid_items/{uid} {
      allow read, write: if false;
    }

    // ─── /users/{uid} — own data only ─────────────────────────
    match /users/{uid} {
      // Read own profile
      allow get: if isOwner(uid);

      // Create own profile (signup) — must include uid field matching auth uid
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && allowedUserCreateFields();

      // Update own profile (settings, preferences)
      // Only the fields listed in allowedUserUpdateFields() may be changed.
      // uid, email, plaid_*, pro, credit_* are immutable from the client
      // (backend Admin SDK bypasses rules and writes those directly).
      allow update: if isOwner(uid)
                    && allowedUserUpdateFields();

      // Never allow client-side deletes — deletion is server-side only
      allow delete: if false;

      // ── Subcollections ──────────────────────────────────────
      // Plaid items subcollection — server-only, contains access_token.
      // Default-deny at the bottom of the file would catch this, but make it
      // explicit so a future permissive rule near here can't accidentally
      // expose tokens.
      match /plaid_items/{itemId} {
        allow read, write: if false;
      }

      // Accounts — Plaid accounts are backend-managed (read-only from client).
      // Manual accounts (manual: true) may be created/updated/deleted by the owner.
      match /accounts/{accountId} {
        allow read: if isOwner(uid);

        // Manual accounts created by the user from the UI
        allow create: if isOwner(uid)
                      && request.resource.data.manual == true
                      && request.resource.data.keys().hasOnly([
                           'name', 'type', 'subtype', 'balance', 'balance_current',
                           'currency', 'mask', 'manual', 'created_at', 'updated_at',
                         ]);
        allow update: if isOwner(uid)
                      && resource.data.manual == true
                      && request.resource.data.manual == true
                      && request.resource.data.keys().hasOnly([
                           'name', 'type', 'subtype', 'balance', 'balance_current',
                           'currency', 'mask', 'manual', 'created_at', 'updated_at',
                         ]);
        allow delete: if isOwner(uid) && resource.data.manual == true;

        // Plaid-synced accounts: no client writes
      }

      // Transactions — read-only from client
      match /transactions/{txnId} {
        allow read:   if isOwner(uid);
        allow write:  if false;  // backend-managed
      }

      // Bills — users can create/update/delete their own bills
      match /bills/{billId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'name', 'amount', 'due_date', 'status',
                           'category', 'type', 'icon', 'color', 'frequency',
                           'paid_at', 'created_at', 'updated_at',
                         ]);
        allow update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'name', 'amount', 'due_date', 'status',
                           'category', 'type', 'icon', 'color', 'frequency',
                           'paid_at', 'created_at', 'updated_at',
                         ]);
        allow delete: if isOwner(uid);
      }

      // Goals — users can manage their own goals
      match /goals/{goalId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'name', 'target', 'current', 'emoji',
                           'target_date', 'created_at', 'updated_at',
                         ]);
        allow update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'name', 'target', 'current', 'emoji',
                           'target_date', 'created_at', 'updated_at',
                         ]);
        allow delete: if isOwner(uid);
      }

      // Budgets — users can manage their own budgets
      match /budgets/{budgetId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'category', 'limit', 'period', 'created_at', 'updated_at',
                         ]);
        allow update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'category', 'limit', 'period', 'created_at', 'updated_at',
                         ]);
        allow delete: if isOwner(uid);
      }

      // Transaction overrides — user-edited names/categories
      match /transaction_overrides/{txnId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'name', 'category', 'updated_at',
                         ]);
        allow update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'name', 'category', 'updated_at',
                         ]);
        allow delete: if isOwner(uid);
      }

      // Notifications — written by backend only; client can mark as read.
      // Note: 'write' covers create+update+delete. Listing create/update/delete
      // explicitly avoids the ambiguity of overlapping allow write: if false.
      match /notifications/{notifId} {
        allow read:   if isOwner(uid);
        allow create: if false;  // backend-managed only
        allow delete: if false;  // backend-managed only
        allow update: if isOwner(uid)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }

      // Credit history — read/write by owner (client saves snapshots after fetching score).
      // Fields written by saveCreditSnapshot() in fc-data.js.
      match /credit_history/{monthId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'month', 'score', 'source', 'fetched_at', 'updated_at',
                           'change', 'rating', 'factors', 'provider',
                         ]);
        allow update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly([
                           'month', 'score', 'source', 'fetched_at', 'updated_at',
                           'change', 'rating', 'factors', 'provider',
                         ]);
        allow delete: if false;
      }

      // Net worth history — read/write by owner (client saves daily snapshots).
      // Single document 'snapshots' with a `data` map of {YYYY-MM-DD: number}.
      // Written by saveNetWorthSnapshot() in fc-data.js.
      match /nw_history/{docId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasOnly(['data', 'updated_at']);
        allow update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly(['data', 'updated_at']);
        allow delete: if false;
      }
    }

    // ─── /referrals — Admin SDK only ──────────────────────────────
    match /referrals/{code} {
      allow read, write: if false;
    }

    // ─── /otp_codes — Admin SDK only ──────────────────────────────
    // 6-digit OTP codes for email verification. Backend-only.
    // Never expose codes to the client — even to the owner.
    match /otp_codes/{uid} {
      allow read, write: if false;
    }

    // ─── /signup_followups — Admin SDK only ───────────────────────
    // Tracks abandoned signup follow-up email state. Backend-only.
    match /signup_followups/{uid} {
      allow read, write: if false;
    }

    // ─── Deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
