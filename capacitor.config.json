{
  "appId": "com.brandon.flowcheck",
  "appName": "FlowCheck",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "Keyboard": {
      "resize": "none",
      "style": "dark",
      "resizeOnFullScreen": false
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "305596636244-f6beahteufti7g85etaiucpo780mkehk.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  },
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#060e18",
    "packageClassList": ["BiometricAuthNative"]
  }
}
