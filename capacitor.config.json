{
  "appId": "com.brandon.flowcheck",
  "appName": "FlowCheck",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#0a1520"
  },
  "plugins": {
    "Keyboard": {
      "resize": "native",
      "style": "default",
      "resizeOnFullScreen": true
    },
    "StatusBar": {
      "backgroundColor": "#0a1520",
      "style": "DARK",
      "overlaysWebView": false
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "305596636244-f6beahteufti7g85etaiucpo780mkehk.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  },
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#0a1520",
    "packageClassList": ["BiometricAuthNative", "CapacitorGoogleAuth"]
  }
}
