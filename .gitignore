# ── Dependencies ────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ────────────────────────────────────────────────
# NOTE: www/ is intentionally tracked — it is the hand-written source code
# for the Capacitor web layer, not a build artifact. Do NOT add it here.
dist/
build/
.output/

# ── Capacitor ────────────────────────────────────────────────────
ios/App/App/capacitor.config.json
# Android — track project files, ignore build artifacts
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.idea/
android/captures/
android/app/.cxx/

# ── Environment & secrets ────────────────────────────────────────
.env
.env.*
!.env.example
*.serviceaccount.json
firebase-adminsdk-*.json
*-service-account.json
google-services.json
GoogleService-Info.plist
# Allow the actual project config files (private repo)
!ios/App/App/GoogleService-Info.plist
!android/app/google-services.json
# Apple private keys (Sign In with Apple, Push certs, etc.)
*.p8
*.p12
AuthKey_*.p8

# ── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── macOS ─────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Lock files (keep package-lock.json, ignore yarn.lock if npm is primary) ──
yarn.lock
.vercel
node_modules/
ios/App/App/public/
GoogleService-Info 2.plist
