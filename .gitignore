.env
.env.*
!.env.example
*.serviceaccount.json
firebase-adminsdk-*.json
*-service-account.json
google-services.json
GoogleService-Info.plist

# ── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── macOS ─────────────────────────────────────────────────────────
