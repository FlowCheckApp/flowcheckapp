# ── Plaid ────────────────────────────────────────────────────────
# Environment: 'sandbox' | 'development' | 'production'
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_or_production_secret

# ── Firebase Admin ────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the entire service account JSON as a single-line string.
# Generate from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Server ────────────────────────────────────────────────────────
# Optional — Railway sets PORT automatically
PORT=8080
