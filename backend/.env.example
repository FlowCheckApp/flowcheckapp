# ── Plaid ────────────────────────────────────────────────────────
# Environment: 'sandbox' | 'development' | 'production'
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_or_production_secret

# ── Firebase Admin ────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the entire service account JSON as a single-line string.
# Generate from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Server ────────────────────────────────────────────────────────
# Set to the public domain of this backend (no trailing slash)
# Used for webhook URLs, email links, and deep links.
BACKEND_URL=https://getflowcheck.app
# Optional — Railway sets PORT automatically
PORT=8080
# Set to 'production' in Railway; 'development' for local testing
NODE_ENV=production

# ── Email (Resend) ────────────────────────────────────────────────
# REQUIRED for OTP verification emails, bill reminders, and all transactional email.
# Get from: https://resend.com → API Keys
# If unset, ALL emails silently fail — users will never receive verification codes.
RESEND_API_KEY=re_your_resend_api_key
# Must be a verified sender domain in Resend dashboard
EMAIL_FROM=FlowCheck <noreply@getflowcheck.app>

# ── RevenueCat webhook ────────────────────────────────────────────
# CRITICAL: if unset, the /webhooks/revenuecat endpoint accepts requests
# without authentication — any caller could grant Pro to any user for free.
# Set this to the "Authorization header value" from RevenueCat dashboard:
#   RevenueCat → Project → Integrations → Webhooks → Authorization header
# Generate with: openssl rand -hex 32
RC_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# ── Unsubscribe link signing ──────────────────────────────────────
# REQUIRED: signs unsubscribe URLs in outbound emails.
# Generate with: openssl rand -hex 32
UNSUB_SECRET=your_unsub_secret

# ── Error tracking (Sentry) ───────────────────────────────────────
# Optional but strongly recommended in production.
# Get from: sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
